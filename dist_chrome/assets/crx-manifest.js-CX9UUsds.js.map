export default "{\"manifest_version\":3,\"name\":\"Plum - AI Web Assistant\",\"version\":\"1.4.0\",\"description\":\"An intelligent chatbot that helps you understand and interact with web content\",\"options_ui\":{\"page\":\"src/pages/options/index.html\"},\"action\":{\"default_title\":\"Open Plum Assistant\",\"default_icon\":{\"32\":\"public/icons/icon-32.png\",\"128\":\"public/icons/icon-128.png\"}},\"icons\":{\"32\":\"public/icons/icon-32.png\",\"128\":\"public/icons/icon-128.png\"},\"permissions\":[\"storage\",\"sidePanel\",\"tabs\",\"activeTab\",\"scripting\",\"clipboardWrite\",\"webNavigation\"],\"side_panel\":{\"default_path\":\"src/pages/panel/index.html\",\"open_panel_on_action_click\":true},\"content_scripts\":[{\"matches\":[\"http://*/*\",\"https://*/*\",\"<all_urls>\"],\"js\":[\"src/pages/content/index.tsx\"],\"css\":[\"contentStyle.css\"],\"run_at\":\"document_end\"}],\"devtools_page\":\"src/pages/devtools/index.html\",\"web_accessible_resources\":[{\"resources\":[\"contentStyle.css\",\"icons/icon-128.png\",\"icons/icon-32.png\"],\"matches\":[]}],\"background\":{\"service_worker\":\"src/pages/background/index.ts\",\"type\":\"module\"}}"